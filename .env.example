# GCP
GOOGLE_CLOUD_PROJECT=pulse-stadium-ai
GOOGLE_CLOUD_LOCATION=asia-south1

# Vertex AI models
VERTEX_MODEL_ORCHESTRATOR=gemini-2.5-pro
VERTEX_MODEL_SPECIALIST=gemini-2.5-flash
VERTEX_MODEL_VISION=gemini-2.5-pro
VERTEX_MODEL_VOICE=gemini-2.5-flash-live

# Firestore
FIRESTORE_DATABASE=(default)
PULSE_VENUE_ID=chinnaswamy

# Pub/Sub topics
PUBSUB_TOPIC_SENSOR_EVENTS=sensor-events
PUBSUB_TOPIC_VISION_FRAMES=vision-frames
PUBSUB_TOPIC_AGENT_EVENTS=agent-events
PUBSUB_TOPIC_FAN_ACTIONS=fan-actions
PUBSUB_TOPIC_STAFF_TASKS=staff-tasks
PUBSUB_TOPIC_SIGNAGE_UPDATES=signage-updates

# Storage
CCTV_BUCKET=pulse-cctv-clips

# ADK / cost tracking
ADK_TRACE_ENABLED=true
COST_BUDGET_PER_SESSION_USD=0.50

# External APIs
CRICAPI_KEY=

# Frontend public (Next.js)
NEXT_PUBLIC_FIREBASE_PROJECT_ID=pulse-stadium-ai
NEXT_PUBLIC_FIRESTORE_DB=(default)
NEXT_PUBLIC_VENUE_ID=chinnaswamy
NEXT_PUBLIC_GEMINI_LIVE_ENDPOINT=
NEXT_PUBLIC_FCM_VAPID_KEY=
